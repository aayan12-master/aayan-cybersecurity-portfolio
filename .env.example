# Admin Authentication
VITE_ADMIN_USERNAME=your_username
VITE_ADMIN_PASSWORD_HASH=your_password_hash

# Session Configuration (milliseconds)
VITE_SESSION_DURATION_MS=86400000

# Rate Limiting
VITE_MAX_LOGIN_ATTEMPTS=5
