# Web3Forms Integration
VITE_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key

# Supabase Integration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key